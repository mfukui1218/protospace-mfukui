<h2>Sign up</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

  <!-- USERNAME -->
  <div class="field">
    <%= f.label :username %><br />
    <%= f.text_field :username, autofocus: true, autocomplete: "username" %>

    <% resource.errors.full_messages_for(:username).each do |message| %>
      <p class="error"><%= message %></p>
    <% end %>
  </div>

  <!-- EMAIL -->
  <div class="field">
    <%= f.label :email %><br />
    <%= f.email_field :email, autocomplete: "email" %>

    <% resource.errors.full_messages_for(:email).each do |message| %>
      <p class="error"><%= message %></p>
    <% end %>
  </div>

  <!-- PROFILE -->
  <div class="field">
    <%= f.label :profile %><br />
    <%= f.text_area :profile, rows: 3 %>

    <% resource.errors.full_messages_for(:profile).each do |message| %>
      <p class="error"><%= message %></p>
    <% end %>
  </div>

  <!-- AFFILIATION -->
  <div class="field">
    <%= f.label :affiliation %><br />
    <%= f.text_field :affiliation %>

    <% resource.errors.full_messages_for(:affiliation).each do |message| %>
      <p class="error"><%= message %></p>
    <% end %>
  </div>

  <!-- POSITION -->
  <div class="field">
    <%= f.label :position %><br />
    <%= f.text_field :position %>

    <% resource.errors.full_messages_for(:position).each do |message| %>
      <p class="error"><%= message %></p>
    <% end %>
  </div>

  <!-- PASSWORD -->
  <div class="field">
    <%= f.label :password %><br />
    <%= f.password_field :password, autocomplete: "new-password" %>

    <% resource.errors.full_messages_for(:password).each do |message| %>
      <p class="error"><%= message %></p>
    <% end %>
  </div>

  <!-- PASSWORD CONFIRMATION -->
  <div class="field">
    <%= f.label :password_confirmation %><br />
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>

    <% resource.errors.full_messages_for(:password_confirmation).each do |message| %>
      <p class="error"><%= message %></p>
    <% end %>
  </div>

  <div class="actions">
    <%= f.submit "Sign up" %>
  </div>

<% end %>

<%= render "devise/shared/links" %>
``